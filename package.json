{
  "name": "open-terminal-lite",
  "version": "1.0.0",
  "description": "Lightweight terminal API for AI agents - a fork of open-webui/open-terminal",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "open-terminal-lite": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js run",
    "dev": "node --watch src/index.js run",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathIgnorePatterns=docker --forceExit",
    "test:docker": "NODE_OPTIONS='--experimental-vm-modules' jest test/docker.test.js --testTimeout=60000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mintplex-Labs/open-terminal-lite.git"
  },
  "homepage": "https://github.com/Mintplex-Labs/open-terminal-lite#readme",
  "bugs": {
    "url": "https://github.com/Mintplex-Labs/open-terminal-lite/issues"
  },
  "author": "Timothy Carambat <tim@anythingllm.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
